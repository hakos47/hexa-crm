DATABASE_URL=postgresql://hakos:nix_password@127.0.0.1:5432/nix_crm
# Web data plane: local uses browser localStorage; central uses /api/rpc + PostgreSQL.
# Defaults: local in vite dev, central in production builds.
# VITE_CRM_MODE=local
# Central API: set POSTGRES_PASSWORD in the Incus secret store, never commit it.
# HEXA_SERVICE_KEYS='[{"keyId":"meiga-2026-07","tenantCode":"MEIGA","secret":"rotate-in-secret-store"}]'
# HEXA_CENTRAL_MODE=1  # no demo seed; provision tenants explicitly
# HEXA_MIGRATION_TOKEN=store-outside-repo  # owner-only POST /api/v1/admin/migrate
# npm run central:provision-tenant  # with DATABASE_URL, HEXA_TENANT_CODE=MEIGA and legal/trade names
# npm run central:provision-api-role  # with owner DATABASE_URL and HEXA_API_DB_USER/PASSWORD
# npm run central:provision-operator  # with owner DATABASE_URL, tenant and operator credentials
# HEXA_API_DATABASE_URL=postgresql://hexa_api:secret@db:5432/hexa_crm
# HEXA_OLLAMA_URL=http://ollama.internal:11434
# HEXA_EMBEDDING_MODEL=nomic-embed-text
